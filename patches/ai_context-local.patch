diff --git a/src/AiContextProviderManager.php b/src/AiContextProviderManager.php
new file mode 100644
index 0000000..e04d8c6
--- /dev/null
+++ b/src/AiContextProviderManager.php
@@ -0,0 +1,70 @@
+<?php
+
+declare(strict_types=1);
+
+namespace Drupal\ai_context;
+
+use Drupal\ai_context\Attribute\AiContextProvider;
+use Drupal\ai_context\Plugin\AiContextProvider\AiContextProviderInterface;
+use Drupal\Core\Cache\CacheBackendInterface;
+use Drupal\Core\Extension\ModuleHandlerInterface;
+use Drupal\Core\Plugin\DefaultPluginManager;
+
+/**
+ * Plugin manager for AiContextProvider plugins.
+ *
+ * Manages discovery and instantiation of provider plugins that contribute
+ * dynamic context content to agent system prompts alongside curated
+ * AiContextItem entities.
+ *
+ * @see \Drupal\ai_context\Attribute\AiContextProvider
+ * @see \Drupal\ai_context\Plugin\AiContextProvider\AiContextProviderInterface
+ */
+class AiContextProviderManager extends DefaultPluginManager {
+
+  /**
+   * Constructs an AiContextProviderManager object.
+   *
+   * @param \Traversable $namespaces
+   *   Root paths keyed by namespace for plugin discovery.
+   * @param \Drupal\Core\Cache\CacheBackendInterface $cache_backend
+   *   The cache backend.
+   * @param \Drupal\Core\Extension\ModuleHandlerInterface $module_handler
+   *   The module handler.
+   */
+  public function __construct(
+    \Traversable $namespaces,
+    CacheBackendInterface $cache_backend,
+    ModuleHandlerInterface $module_handler,
+  ) {
+    parent::__construct(
+      'Plugin/AiContextProvider',
+      $namespaces,
+      $module_handler,
+      AiContextProviderInterface::class,
+      AiContextProvider::class,
+    );
+    $this->alterInfo('ai_context_provider_info');
+    $this->setCacheBackend($cache_backend, 'ai_context_provider_plugins');
+  }
+
+  /**
+   * Gets all provider instances sorted ascending by weight.
+   *
+   * @return \Drupal\ai_context\Plugin\AiContextProvider\AiContextProviderInterface[]
+   *   Provider instances keyed by plugin ID.
+   */
+  public function getProvidersSortedByWeight(): array {
+    $instances = [];
+    foreach ($this->getDefinitions() as $plugin_id => $definition) {
+      $instances[$plugin_id] = $this->createInstance($plugin_id);
+    }
+
+    uasort($instances, static function (AiContextProviderInterface $a, AiContextProviderInterface $b): int {
+      return $a->getWeight() <=> $b->getWeight();
+    });
+
+    return $instances;
+  }
+
+}
