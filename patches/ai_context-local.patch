@@ -0,0 +1,51 @@
+<?php
+
+declare(strict_types=1);
+
+namespace Drupal\ai_context\Plugin\AiContextProvider;
+
+use Drupal\ai_agents\Event\BuildSystemPromptEvent;
+use Drupal\Component\Plugin\PluginInspectionInterface;
+
+/**
+ * Interface for AI Context Provider plugins.
+ *
+ * Provider plugins contribute dynamic text content to agent system prompts
+ * alongside curated AiContextItem entities.
+ *
+ * @see \Drupal\ai_context\Attribute\AiContextProvider
+ * @see \Drupal\ai_context\AiContextProviderManager
+ */
+interface AiContextProviderInterface extends PluginInspectionInterface {
+
+  /**
+   * Determines whether this provider should run for the given event.
+   *
+   * @param \Drupal\ai_agents\Event\BuildSystemPromptEvent $event
+   *   The system prompt event.
+   *
+   * @return bool
+   *   TRUE if this provider's content should be included.
+   */
+  public function isApplicable(BuildSystemPromptEvent $event): bool;
+
+  /**
+   * Returns the context content to append to the system prompt.
+   *
+   * @param \Drupal\ai_agents\Event\BuildSystemPromptEvent $event
+   *   The system prompt event.
+   *
+   * @return string
+   *   The content string, or '' if nothing to contribute.
+   */
+  public function getContent(BuildSystemPromptEvent $event): string;
+
+  /**
+   * Gets the weight for ordering relative to other providers.
+   *
+   * @return int
+   *   The weight. Lower values run first.
+   */
+  public function getWeight(): int;
+
+}
