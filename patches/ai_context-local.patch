@@ -0,0 +1,44 @@
+<?php
+
+declare(strict_types=1);
+
+namespace Drupal\ai_context\Attribute;
+
+use Drupal\Component\Plugin\Attribute\Plugin;
+use Drupal\Core\StringTranslation\TranslatableMarkup;
+
+/**
+ * Defines an AI Context Provider plugin attribute.
+ *
+ * Plugin Namespace: Plugin\AiContextProvider.
+ *
+ * Provider plugins contribute dynamic content to agent system prompts,
+ * supplementing curated AiContextItem entities with programmatic context.
+ *
+ * @see \Drupal\ai_context\Plugin\AiContextProvider\AiContextProviderInterface
+ * @see \Drupal\ai_context\AiContextProviderManager
+ * @see plugin_api
+ */
+#[\Attribute(\Attribute::TARGET_CLASS)]
+final class AiContextProvider extends Plugin {
+
+  /**
+   * Constructs an AiContextProvider attribute.
+   *
+   * @param string $id
+   *   The plugin ID.
+   * @param \Drupal\Core\StringTranslation\TranslatableMarkup $label
+   *   The human-readable label.
+   * @param int $weight
+   *   The weight for ordering. Lower weights run first.
+   * @param class-string|null $deriver
+   *   (optional) The deriver class.
+   */
+  public function __construct(
+    public readonly string $id,
+    public readonly TranslatableMarkup $label,
+    public readonly int $weight = 0,
+    public readonly ?string $deriver = NULL,
+  ) {}
+
+}
